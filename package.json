{
  "name": "diglett",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <27"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "changelog": "tsx scripts/changelog.ts",
    "ci": "biome ci .",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "check": "biome check --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.105.0",
    "@octokit/rest": "21.1.1",
    "@slack/bolt": "4.7.3",
    "@slack/web-api": "7.17.0",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "pino": "10.3.1",
    "zod": "4.4.3",
    "zod-to-json-schema": "3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.0.0",
    "pino-pretty": "13.1.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
